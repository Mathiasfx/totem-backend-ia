# Variables obligatorias
GOOGLE_PROJECT_ID=mi-proyecto-gcp
GOOGLE_APPLICATION_CREDENTIALS=./google-creds.json
GCS_BUCKET_NAME=nombre-del-bucket

# Servidor
PORT=3000

# URL base para enlaces cortos en QR (elegir una de las dos opciones)
# Opción A: IP de la máquina en la LAN
HOST_IP=192.168.0.83
# Opción B: URL pública (tiene precedencia sobre HOST_IP)
# PUBLIC_BASE_URL=https://totem.midominio.com

# Tiempo de vida de URLs firmadas GCS en segundos (máx 604800 = 7 días)
# SIGNED_URL_TTL_SECONDS=604800
