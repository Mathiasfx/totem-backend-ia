# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example
.env.local
.env.*.local

# Google Cloud / credenciales (nunca commitear)
google-creds.json
*-creds.json
*service-account*.json
application_default_credentials.json

# Claves y certificados
*.pem
*.p12
*.key
id_rsa
id_ed25519
*.keystore

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/

# OS files
.DS_Store
Thumbs.db

# IDE / Editor
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Datos generados en runtime (rutas usadas en src/index.js)
src/uploads/*
!src/uploads/.gitkeep
src/outputs/*
